<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"/>
    <title>{{ title }}</title>

    <!-- Meta Tags for Open Graph -->
    <meta name="description" content="{{ description or meta.defaultDescription }}">
    <meta property="og:url" content="{{ meta.siteUrl }}{{ url or '/' }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ social_title or title }}">
    <meta property="og:description" content="{{ social_description or description or meta.defaultDescription }}">
    <meta property="og:image" content="{{ meta.siteUrl }}{{ meta.socialImagePath }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:domain" content="{{ meta.socialDomain }}">
    <meta property="twitter:url" content="{{ meta.siteUrl }}{{ url or '/' }}">
    <meta name="twitter:title" content="{{ social_title or title }}">
    <meta name="twitter:description" content="{{ social_description or description or meta.defaultDescription }}">
    <meta name="twitter:image" content="{{ meta.siteUrl }}{{ meta.socialImagePath }}">

    <link rel="icon" type="image/x-icon" href="static/favicon.ico">
    <script src="static/anime.min.js"></script>
    <script src="static/scripts/site.js" defer></script>
    <link rel="stylesheet" href="static/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@300;500&display=swap" rel="stylesheet">
    <script src="https://code.iconify.design/2/2.2.1/iconify.min.js"></script>
  </head>
  <body>
    <div class="container">
      <div class="row">
        <div class="twelve column">
          {% if not use_404_logo %}
            {{comp.dominick_logo_svg() | await | safe}}
            {{comp.dom_logo_viz() | await | safe}}
          {% else %}
            {{comp.404_svg() | await | safe}}
          {% endif %}
        </div>
      </div>
      {{ content | safe }}
    </div>
  </body>
</html>